# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# Noma: el conocimiento interno y los datos del estudio viven en el repo privado noma-ops.
# Estas carpetas ya no forman parte de noma-app; se ignoran por si reaparecen localmente.
/context/
/data/
/output/

# typescript
*.tsbuildinfo
next-env.d.ts

# Secretos / credenciales — NO versionar en ningún caso
*.apps.googleusercontent.com.json
client_secret*.json
credentials*.json
token*.json
*.key
*.p12
*.crt
.venv/
__pycache__/
*.pyc

# Herramientas y caches externos (no versionar)
.codex/
