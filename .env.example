# ─────────────────────────────────────────────────────────────
# Noma · variables de entorno (copiar a .env.local y completar)
# ─────────────────────────────────────────────────────────────

# Supabase ----------------------------------------------------
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
# Solo servidor (scripts/seed, operaciones admin). NUNCA exponer al cliente.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Base de datos (Drizzle) -------------------------------------
# DEV LOCAL (recomendado): Postgres local, no toca datos reales. `createdb noma`.
#   Baseline: `npm run db:deploy` (migraciones) + `npm run db:seed`.
DATABASE_URL="postgresql://postgres@localhost:5432/noma"
# PROD (Vercel): usar el POOLER de Supabase (puerto 6543):
#   postgresql://postgres.PROJECT:[PASSWORD]@aws-...pooler.supabase.com:6543/postgres
# MIGRACIONES (GitHub Action): usar la CONEXIÓN DIRECTA (puerto 5432) como secreto
#   DATABASE_URL en GitHub → Settings → Secrets and variables → Actions.

# Auth (Google Workspace SSO) ---------------------------------
# Se configura el provider Google en Supabase Auth. Opcional: restringir dominio.
NEXT_PUBLIC_ALLOWED_EMAIL_DOMAIN="studionomade.cl"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Roles -------------------------------------------------------
# Superadmin: ve TODOS los módulos (incluye Finanzas/CFO) + administración.
NOMA_SUPERADMIN_EMAILS="sebastian@studionomade.cl,ana@studionomade.cl,sales@studionomade.cl"
# Finanzas (CFO): ver y operar el módulo financiero.
NOMA_FINANCE_EMAILS="sales@studionomade.cl"
# Admin: borrado/configuración global.
NOMA_ADMIN_EMAILS="branding@studionomade.cl"

# Bypass de auth SOLO dev local (opcional) --------------------
# Si se define y NODE_ENV!=production, entra como este correo sin Google/Supabase.
# NUNCA definir en producción. Comentar para exigir login real en local.
# NOMA_DEV_AUTH_EMAIL="sebastian@studionomade.cl"

# Cobranza (CFO) — remitente de los correos de cobranza --------
# Casilla desde la que salen los correos. Debe haber iniciado sesión en Noma una
# vez (para tener su refresh token de Gmail). Requiere GOOGLE_CLIENT_ID/SECRET.
NOMA_COBRANZA_FROM="sales@studionomade.cl"

# Conversor de moneda (UF / dólar observado) ------------------
# Fuente por defecto: https://mindicador.cl (Banco Central de Chile, sin API key).
MINDICADOR_API_URL="https://mindicador.cl/api"

# IA (preparado para fase futura; no se usa en V1) ------------
# ANTHROPIC_API_KEY="sk-ant-..."
# AI_PROVIDER="anthropic"
# AI_MODEL="claude-opus-4-8"
